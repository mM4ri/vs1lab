<!DOCTYPE html>

<!-- File origin: VS1LAB A1a -->

<html lang="en">

<head>
        <!-- Leaflet CSS and JavaScript (in this order) -->
    <link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
        
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GeoTagApp</title>
    <link rel="stylesheet" href="./stylesheets/style.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body>
    <header class="header">
        <img src="./images/location.png" class="header__image" alt="an image of a map and location">
        <h1 class="header__title">GeoTagApp</h1>
        <nav class="header__navigation">
            <a href="#">About</a> | <a href="#">Help</a> | <a href="/">Home</a>
        </nav>
    </header>

    <main class="main">
        <div class="row"> <!--neu-->
        <section class="main__tagging tagging col-3"> <!-- ← col-3 NEU -->
            <h2>Tagging</h2>

            <!-- ############### VS1Lab 1a Form 1 Start -->
            <form id="tag-form" action="/tagging" method="post">

                <!-- ... your code here ... -->
                <fieldset>
    <legend>Add a new GeoTag</legend>

    <label for="tag-latitude">Latitude:</label>
    <!-- geändert-->
    <input type="text" id="tag-latitude" name="latitude" value="<%= latitude %>" placeholder="e.g. 49.01379" readonly>

    <label for="tag-longitude">Longitude:</label>
    <!-- geändert-->
    <input type="text" id="tag-longitude" name="longitude" value="<%= longitude %>" placeholder="e.g. 8.390071" readonly>

    <label for="tag-name">Name:</label>
    <input type="text" id="tag-name" name="name" placeholder="e.g. Central Berlin" required maxlength="10" pattern="[A-Za-z]{1,10}">

    <label for="tag-hashtag">Hashtag:</label>

    <input type="text" id="tag-hashtag" name="hashtag" placeholder="e.g. #ber" pattern="#[A-Za-z]{1,10}" maxlength="11">

    <input type="submit" value="Add Tag">
</fieldset>
            </form>
            <!-- ############### VS1Lab 1a Form 1 End -->

        </section>

                <section class="main__discovery discovery col-9"> <!-- col-9  -->
            <h2 class="discovery__title">Discovery</h2>

            <!-- ############### VS1Lab 1a Form 2 Start -->
            <form class="discovery__search" id="discoveryFilterForm" action="/discovery" method="post">

                <!-- ... your code here ... -->
                <fieldset>
    <legend>Search</legend>

    <label for="discovery-searchterm">Search term or keywords:</label>
    <input type="text" id="discovery-searchterm" name="searchterm" placeholder="e.g. Berlin">
   <!-- geändert-->
    <input type="hidden" id="discovery-latitude" name="latitude" value="<%= latitude %>">
    <!-- geändert-->
    <input type="hidden" id="discovery-longitude" name="longitude" value="<%= longitude %>">

    <input type="submit" value="Search">
</fieldset>
            </form>
            <!-- ############### VS1Lab 1a Form 2 End -->

            <div class="discovery__wrapper row"> <!-- row  -->
                <div class="discovery__taglist col-4"> <!-- col-4 -->

                    <ul class="discovery__results" id="discoveryResults">
                            <% if (taglist !== undefined) taglist.forEach(function(gtag) { %>
                            <li><%= gtag.name %> ( <%= gtag.latitude %>,<%= gtag.longitude %>) <%= gtag.hashtag %> </li>
                            <% }); %>
                    </ul>
                </div>

                 <!-- GEÄNDERT Teil 3-->
                    <div id="map" class="discovery__map col-8" data-tags='<%- JSON.stringify(taglist) %>'> <!-- col-8  -->
                    <img src="./images/mapview.jpg" alt="a map with locations" id="mapView" />
                    <p>Result map</p> <!-- von span zu p gewechselt-->
                </div>
            </div>
        </section>
        </div>
    </main>

    <footer class="footer">
        <span>(c) 2021/22 HKA_IWI_VSYS</span>
    </footer>
    <!-- Load JavaScripts

        ================================================== -->

    <!-- Placed at the end of the document so the pages load faster -->

    <!-- GEÄNDERT -->

<script src="./javascripts/location-helper.js"></script>

<script src="./javascripts/map-manager.js"></script>

<script src="./javascripts/geotagging.js"></script>

<!-- ende -->
</body>

</html>